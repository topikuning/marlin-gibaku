# ── Database (Railway Postgres / lokal) ──────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marlin?schema=public"

# ── Auth.js v5 ───────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET="ganti-dengan-secret-acak-min-32-char"
# URL aplikasi (dev: http://localhost:3000)
AUTH_URL="http://localhost:3000"

# ── Feature flags ────────────────────────────────────────────────
# OTP WA via WAHA — di-drop untuk sekarang (DECISIONS 019), biarkan false
FEATURE_WAHA_OTP="false"

# Seed data awal + demo user otomatis saat deploy (scripts/release.sh).
# Set "true" untuk deploy pertama, lalu "false"/hapus. Lihat docs/DEPLOY_RAILWAY.md
SEED_ON_DEPLOY="false"

# ── Cloudflare R2 (arsip dokumen + foto) ─────────────────────────
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET="marlin-gibaku"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
