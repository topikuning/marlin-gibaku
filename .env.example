# ── Wajib ────────────────────────────────────────────────────
APP_ENV=development                # development | test | production
DATABASE_URL=postgresql://marlin:marlin@localhost:5432/marlin_dev
SESSION_SECRET=                    # min 32 karakter acak: openssl rand -hex 32

# ── Cloudflare R2 (opsional — fitur upload nonaktif bila kosong) ──
