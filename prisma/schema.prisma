// MARLIN · Prisma Schema (rebuild)
// Sumber keputusan: docs/rebuild/DOMAIN_MODEL.md
// Naming: snake_case DB via @map/@@map, camelCase TS.
// Uang = BigInt rupiah. Volume = Decimal(15,3). Waktu = Timestamptz (logika Asia/Jakarta).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  program_director
  regional_manager
  project_manager
  site_manager
  field_supervisor
  exec_viewer
}

/// Lifecycle paket — SATU funnel (menggantikan ProspekStage + ProcurementStage + DocumentStage lama)
enum PackageStage {
  prospek
  tender
  penetapan
  kontrak
  pelaksanaan
  serah_terima
  selesai
  batal
}

/// Status fisik lokasi (orthogonal terhadap PackageStage)
enum LocationStatus {
  persiapan
  berjalan
  terhenti
  selesai
  pho
  pemeliharaan
  fho
  batal
}

enum RabRevisionSource {
  hps_awal
  adendum
}

enum RevisionStatus {
  draft
  aktif
  digantikan
}

enum RabNodeKind {
  kategori
  sub
  grup
  item
}

enum BaselineSource {
  auto
  adendum
  manual
}

/// Workflow laporan harian terpadu
enum DailyReportStatus {
  draft
  dikirim
  perlu_koreksi
  disetujui
  final
}

enum WeatherCode {
  cerah
  berawan
  hujan_ringan
  hujan_deras
  angin_kencang
  banjir
}

enum WorkerRole {
  site_manager
  pelaksana
  mandor
  kepala_tukang
  tukang_bongkar
  tukang_batu
  tukang_besi
  tukang_kayu
  tukang_pipa
  tukang_listrik
  tukang_cat
  tenaga
  logistik
  operator
}

enum PhotoVerification {
  pending
  passed
  flagged_gps
  flagged_time
  flagged_duplicate
  rejected
}

/// Jenis kegiatan lapangan non-pekerjaan (dokumentasi, bukan progres volume)
enum FieldActivityType {
  rapat_pcm // Rapat Persiapan Pelaksanaan (PCM)
  pengukuran_uitzet // Pengukuran / uitzet / setting out
  mc0 // Mutual Check awal (MC-0)
  sosialisasi // Sosialisasi ke masyarakat/pihak terkait
  mobilisasi // Mobilisasi alat/material/personel
  dokumentasi_0 // Dokumentasi kondisi awal (0%)
  lainnya
}

/// Alur ringkas kegiatan lapangan: draft → final (dokumentasi, tanpa approval)
enum FieldActivityStatus {
  draft
  final
}

enum IssueSeverity {
  rendah
  sedang
  tinggi
  kritis
}

enum IssueStatus {
  terbuka
  ditangani
  selesai
}

enum RecoveryStatus {
  direncanakan
  berjalan
  selesai
  batal
}

enum CostCategory {
  material
  upah
  alat
  subkon
  overhead
  transport
  lain
}

enum CommitmentType {
  po
  kontrak_vendor
  kasbon
}

enum ApprovalStatus {
  draft
  diajukan
  disetujui
  ditolak
  batal
}

enum InvoiceStatus {
  diajukan
  disetujui
  ditolak
  dibayar_sebagian
  lunas
}

enum BillingStatus {
  draft
  diajukan
  disetujui
  cair_sebagian
  cair
  ditolak
}

enum MilestoneStatus {
  belum_dimulai
  berjalan
  menunggu_pihak_lain
  perlu_perbaikan
  selesai
  tidak_berlaku
}

/// Fase administrasi PBJ untuk dokumen & milestone
enum AdminPhase {
  pemilihan
  penunjukan
  kontrak
  mulai_kerja
  pelaksanaan
  adendum
  serah_terima
  pembayaran
  lainnya
}

enum DocumentType {
  undangan
  ba_penjelasan
  penawaran
  ba_evaluasi
  ba_klarifikasi
  ba_negosiasi
  penetapan_pemenang
  sanggah
  sppbj
  kontrak
  jaminan
  spmk
  ba_serah_terima_lapangan
  pcm
  mc0
  laporan
  mc_berkala
  adendum
  surat_kendala
  surat_peringatan
  bast_pho
  bast_fho
  ba_pembayaran
  invoice
  faktur_pajak
  hps
  lainnya
}

enum AlertSeverity {
  info
  warning
  critical
}

// ─────────────────────────────────────────────────────────────
// IDENTITAS & AKSES
// ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users            User[]
  packages         Package[]
  vendors          Vendor[]
  documents        Document[]
  masterLocations  MasterLocation[]

  @@map("organizations")
}

/// Katalog lokasi "tertanam di awal" — BELUM terikat paket/kontrak. Sumber data
/// awal (impor lokasi_awal.xlsx). Dipakai menu bypass admin untuk membuat proyek
/// langsung ke tahap Kontrak: satu master → satu Location riil (assignedLocation).
/// Perusahaan (candidateVendor) hanya hint teks — TIDAK dihubungkan relasional
/// ke lokasi; master perusahaan tetap tabel Vendor.
model MasterLocation {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  province           String
  regency            String
  district           String?
  village            String
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  candidateVendor    String?  @map("candidate_vendor")
  assignedLocationId String?  @unique @map("assigned_location_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization     Organization @relation(fields: [orgId], references: [id])
  assignedLocation Location?    @relation(fields: [assignedLocationId], references: [id])

  @@unique([orgId, province, regency, district, village])
  @@index([orgId])
  @@map("master_locations")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  orgId              String    @map("org_id") @db.Uuid
  username           String?   @unique
  email              String?   @unique
  phone              String?   @map("phone")
  fullName           String    @map("full_name")
  passwordHash       String    @map("password_hash")
  role               UserRole
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  tokenVersion       Int       @default(0) @map("token_version")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz
  // Pembuat akun (berjenjang: PM→SM/Mandor, SM→Mandor). Null utk akun awal/seed.
  createdById        String?   @map("created_by_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id])
  sessions     Session[]
  assignments  LocationAssignment[]
  auditLogs    AuditLog[]
  creator      User?   @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[]  @relation("UserCreator")

  @@index([orgId])
  @@index([role])
  @@index([createdById])
  @@map("users")
}

/// Session DB-backed: revocable. id = SHA-256 hash token (token asli hanya di cookie).
model Session {
  id           String    @id
  userId       String    @map("user_id") @db.Uuid
  tokenVersion Int       @map("token_version")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  ip           String?
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

/// Rate limit login per identifier+IP (sliding window)
model LoginAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  ip         String
  success    Boolean
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([identifier, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

model LocationAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  locationId   String    @map("location_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  unassignedAt DateTime? @map("unassigned_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@index([locationId])
  @@map("location_assignments")
}

// ─────────────────────────────────────────────────────────────
// PAKET, KONTRAK, LOKASI
// ─────────────────────────────────────────────────────────────

/// Spine lifecycle: prospek → tender → penetapan → kontrak → pelaksanaan → serah_terima → selesai | batal
model Package {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  name          String
  packageNumber String?      @map("package_number")
  ownerAgency   String       @default("KKP") @map("owner_agency")
  hpsValue      BigInt       @default(0) @map("hps_value")
  stage         PackageStage @default(prospek)
  province      String?
  candidateVendorName String? @map("candidate_vendor_name")
  note          String?
  // Dibuat via jalur cepat admin (bypass proses pra-kontrak); dokumen menyusul.
  isBypass      Boolean      @default(false) @map("is_bypass")
  cancelReason  String?      @map("cancel_reason")
  createdById   String?      @map("created_by_id") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization          @relation(fields: [orgId], references: [id])
  contract     Contract?
  locations    Location[]
  stageHistory PackageStageHistory[]
  documents    Document[]
  milestones   AdminMilestone[]

  @@index([orgId, stage])
  @@map("packages")
}

/// APPEND-ONLY (trigger): histori transisi stage paket
model PackageStageHistory {
  id          String        @id @default(uuid()) @db.Uuid
  packageId   String        @map("package_id") @db.Uuid
  fromStage   PackageStage? @map("from_stage")
  toStage     PackageStage  @map("to_stage")
  changedById String        @map("changed_by_id") @db.Uuid
  changedAt   DateTime      @default(now()) @map("changed_at") @db.Timestamptz
  note        String?

  package Package @relation(fields: [packageId], references: [id])

  @@index([packageId, changedAt])
  @@map("package_stage_history")
}

model Vendor {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  npwp      String?
  contact   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id])
  contracts    Contract[]
  commitments  Commitment[]

  @@unique([orgId, name])
  @@map("vendors")
}

model Contract {
  id              String   @id @default(uuid()) @db.Uuid
  packageId       String   @unique @map("package_id") @db.Uuid
  vendorId        String   @map("vendor_id") @db.Uuid
  contractNumber  String   @unique @map("contract_number")
  // Nama pekerjaan RESMI (judul kontrak, biasanya panjang) — untuk dokumen/cetak.
  // Terpisah dari Package.name (label pendek untuk daftar/tampilan).
  workTitle       String?  @map("work_title")
  contractValue   BigInt   @map("contract_value")
  ppnPercent      Decimal  @default(11) @map("ppn_percent") @db.Decimal(5, 2)
  advancePercent  Decimal? @map("advance_percent") @db.Decimal(5, 2)
  retentionPercent Decimal? @map("retention_percent") @db.Decimal(5, 2)
  signedDate      DateTime @map("signed_date") @db.Date
  // Masa pelaksanaan (hari kalender) = tulang punggung jadwal. Tanggal mulai
  // (SPMK) & selesai baru terisi saat SPMK terbit — sebelum itu null (jadwal
  // relatif dari durationDays; kalender belum terpetakan).
  durationDays    Int      @default(150) @map("duration_days")
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  paymentTerms    String?  @map("payment_terms")
  // Penanda tangan dokumen KKP (opsional, bisa diganti kapan saja bila ada
  // pergantian personel). PPK = pihak KKP; Pengawas = konsultan; Penyedia = pelaksana.
  ppkName               String? @map("ppk_name")
  ppkNip                String? @map("ppk_nip")
  supervisorName        String? @map("supervisor_name")
  supervisorFirm        String? @map("supervisor_firm")
  contractorSignerName  String? @map("contractor_signer_name")
  contractorSignerTitle String? @map("contractor_signer_title")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  package       Package             @relation(fields: [packageId], references: [id])
  vendor        Vendor              @relation(fields: [vendorId], references: [id])
  amendments    ContractAmendment[]
  ownerBillings OwnerBilling[]
  documents     Document[]

  @@index([vendorId])
  @@map("contracts")
}

/// APPEND-ONLY (trigger): adendum/CCO
model ContractAmendment {
  id            String   @id @default(uuid()) @db.Uuid
  contractId    String   @map("contract_id") @db.Uuid
  ccoNumber     String   @map("cco_number")
  valueDelta    BigInt   @map("value_delta")
  endDateDelta  Int      @map("end_date_delta")
  effectiveDate DateTime @map("effective_date") @db.Date
  reason        String
  createdById   String?  @map("created_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  contract     Contract      @relation(fields: [contractId], references: [id])
  documents    Document[]
  rabRevisions RabRevision[]

  @@unique([contractId, ccoNumber])
  @@map("contract_amendments")
}

model Location {
  id        String         @id @default(uuid()) @db.Uuid
  packageId String         @map("package_id") @db.Uuid
  name      String
  slug      String         @unique
  village   String
  district  String?        // kecamatan (opsional)
  regency   String
  province  String
  gpsLat    Decimal?       @map("gps_lat") @db.Decimal(10, 7)
  gpsLng    Decimal?       @map("gps_lng") @db.Decimal(10, 7)
  status    LocationStatus @default(persiapan)
  isActive  Boolean        @default(false) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  package       Package                 @relation(fields: [packageId], references: [id])
  statusHistory LocationStatusHistory[]
  assignments   LocationAssignment[]
  rabRevisions  RabRevision[]
  baselines     Baseline[]
  weeklyPlans   WeeklyPlan[]
  dailyReports  DailyReport[]
  fieldActivities FieldActivity[]
  issues        Issue[]
  budgetLines   BudgetLine[]
  commitments   Commitment[]
  expenses      Expense[]
  invoices      Invoice[]
  documents     Document[]
  milestones    AdminMilestone[]
  alerts        Alert[]
  masterLocation MasterLocation?

  @@index([packageId])
  @@index([province])
  @@index([status])
  @@map("locations")
}

/// APPEND-ONLY (trigger)
model LocationStatusHistory {
  id          String          @id @default(uuid()) @db.Uuid
  locationId  String          @map("location_id") @db.Uuid
  fromStatus  LocationStatus? @map("from_status")
  toStatus    LocationStatus  @map("to_status")
  changedById String          @map("changed_by_id") @db.Uuid
  changedAt   DateTime        @default(now()) @map("changed_at") @db.Timestamptz
  note        String?

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, changedAt])
  @@map("location_status_history")
}

// ─────────────────────────────────────────────────────────────
// RAB & BASELINE
// ─────────────────────────────────────────────────────────────

model RabRevision {
  id               String            @id @default(uuid()) @db.Uuid
  locationId       String            @map("location_id") @db.Uuid
  revisionNo       Int               @map("revision_no")
  source           RabRevisionSource
  amendmentId      String?           @map("amendment_id") @db.Uuid
  status           RevisionStatus    @default(draft)
  totalValue       BigInt            @map("total_value")
  note             String?
  sourceDocumentId String?           @map("source_document_id") @db.Uuid
  createdById      String?           @map("created_by_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  supersededAt     DateTime?         @map("superseded_at") @db.Timestamptz

  location       Location           @relation(fields: [locationId], references: [id])
  amendment      ContractAmendment? @relation(fields: [amendmentId], references: [id])
  sourceDocument Document?          @relation("rabSourceDoc", fields: [sourceDocumentId], references: [id])
  nodes          RabNode[]
  baselines      Baseline[]

  @@unique([locationId, revisionNo])
  @@index([locationId, status])
  @@map("rab_revisions")
}

/// Pohon RAB satu tabel (kategori → sub → grup → item).
/// lineageKey = path stabil ("I#6.1#a") untuk carry-over realisasi lintas revisi.
model RabNode {
  id         String      @id @default(uuid()) @db.Uuid
  revisionId String      @map("revision_id") @db.Uuid
  parentId   String?     @map("parent_id") @db.Uuid
  kind       RabNodeKind
  code       String
  name       String
  volume     Decimal?    @db.Decimal(15, 3)
  unit       String?
  unitPrice  Decimal?    @map("unit_price") @db.Decimal(15, 2)
  amount     BigInt      @default(0)
  lineageKey String      @map("lineage_key")
  sortOrder  Int         @map("sort_order")

  revision    RabRevision       @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  parent      RabNode?          @relation("rabTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    RabNode[]         @relation("rabTree")
  reportItems DailyReportItem[]
  planItems   WeeklyPlanItem[]

  @@unique([revisionId, lineageKey])
  @@index([revisionId, parentId, sortOrder])
  @@index([revisionId, kind])
  @@map("rab_nodes")
}

/// Kurva-S rencana ber-versi (dulu ScurvePlan)
model Baseline {
  id            String         @id @default(uuid()) @db.Uuid
  locationId    String         @map("location_id") @db.Uuid
  baselineNo    Int            @map("baseline_no")
  source        BaselineSource
  status        RevisionStatus @default(aktif)
  rabRevisionId String?        @map("rab_revision_id") @db.Uuid
  contractDays  Int            @map("contract_days")
  note          String?
  createdById   String?        @map("created_by_id") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  supersededAt  DateTime?      @map("superseded_at") @db.Timestamptz

  location    Location       @relation(fields: [locationId], references: [id])
  rabRevision RabRevision?   @relation(fields: [rabRevisionId], references: [id])
  points      BaselinePoint[]

  @@unique([locationId, baselineNo])
  @@index([locationId, status])
  @@map("baselines")
}

model BaselinePoint {
  id         String  @id @default(uuid()) @db.Uuid
  baselineId String  @map("baseline_id") @db.Uuid
  weekNumber Int     @map("week_number")
  plannedPct Decimal @map("planned_pct") @db.Decimal(6, 3)

  baseline Baseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@unique([baselineId, weekNumber])
  @@map("baseline_points")
}

model WeeklyPlan {
  id          String    @id @default(uuid()) @db.Uuid
  locationId  String    @map("location_id") @db.Uuid
  weekNumber  Int       @map("week_number")
  weekStart   DateTime  @map("week_start") @db.Date
  weekEnd     DateTime  @map("week_end") @db.Date
  note        String?
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  location Location         @relation(fields: [locationId], references: [id])
  items    WeeklyPlanItem[]

  @@unique([locationId, weekNumber])
  @@map("weekly_plans")
}

model WeeklyPlanItem {
  id           String  @id @default(uuid()) @db.Uuid
  weeklyPlanId String  @map("weekly_plan_id") @db.Uuid
  rabNodeId    String  @map("rab_node_id") @db.Uuid
  targetVolume Decimal @map("target_volume") @db.Decimal(15, 3)
  priority     Int     @default(5)
  picName      String? @map("pic_name")
  note         String?

  plan    WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  rabNode RabNode    @relation(fields: [rabNodeId], references: [id])

  @@unique([weeklyPlanId, rabNodeId])
  @@map("weekly_plan_items")
}

// ─────────────────────────────────────────────────────────────
// PELAKSANAAN HARIAN (SATU entitas laporan)
// ─────────────────────────────────────────────────────────────

model DailyReport {
  id            String            @id @default(uuid()) @db.Uuid
  locationId    String            @map("location_id") @db.Uuid
  reportDate    DateTime          @map("report_date") @db.Date
  status        DailyReportStatus @default(draft)
  weather       WeatherCode?
  workStart     String?           @map("work_start")
  workEnd       String?           @map("work_end")
  notes         String?
  gpsLat        Decimal?          @map("gps_lat") @db.Decimal(10, 7)
  gpsLng        Decimal?          @map("gps_lng") @db.Decimal(10, 7)
  createdById   String            @map("created_by_id") @db.Uuid
  submittedById String?           @map("submitted_by_id") @db.Uuid
  submittedAt   DateTime?         @map("submitted_at") @db.Timestamptz
  verifiedById  String?           @map("verified_by_id") @db.Uuid
  verifiedAt    DateTime?         @map("verified_at") @db.Timestamptz
  finalizedById String?           @map("finalized_by_id") @db.Uuid
  finalizedAt   DateTime?         @map("finalized_at") @db.Timestamptz
  finalSnapshot Json?             @map("final_snapshot")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  location      Location                   @relation(fields: [locationId], references: [id])
  items         DailyReportItem[]
  workers       DailyReportWorker[]
  materials     DailyReportMaterial[]
  equipment     DailyReportEquipment[]
  statusHistory DailyReportStatusHistory[]
  photos        Photo[]
  issues        Issue[]

  @@unique([locationId, reportDate])
  @@index([status])
  @@index([locationId, status])
  @@map("daily_reports")
}

/// APPEND-ONLY (trigger): histori transisi + alasan koreksi
model DailyReportStatusHistory {
  id          String             @id @default(uuid()) @db.Uuid
  reportId    String             @map("report_id") @db.Uuid
  fromStatus  DailyReportStatus? @map("from_status")
  toStatus    DailyReportStatus  @map("to_status")
  changedById String             @map("changed_by_id") @db.Uuid
  changedAt   DateTime           @default(now()) @map("changed_at") @db.Timestamptz
  reason      String?

  report DailyReport @relation(fields: [reportId], references: [id])

  @@index([reportId, changedAt])
  @@map("daily_report_status_history")
}

/// Kegiatan lapangan NON-PEKERJAAN (dokumentasi foto) — mis. rapat PCM,
/// pengukuran/uitzet/MC-0, sosialisasi, mobilisasi, dokumentasi kondisi 0%.
/// Terpisah dari DailyReport (yang mengukur progres volume RAB): tak butuh
/// SPMK/minggu, boleh banyak per hari, alur ringkas draft → final.
model FieldActivity {
  id            String              @id @default(uuid()) @db.Uuid
  locationId    String              @map("location_id") @db.Uuid
  activityDate  DateTime            @map("activity_date") @db.Date
  type          FieldActivityType
  title         String
  notes         String?
  participants  String?             @map("participants")
  gpsLat        Decimal?            @map("gps_lat") @db.Decimal(10, 7)
  gpsLng        Decimal?            @map("gps_lng") @db.Decimal(10, 7)
  status        FieldActivityStatus @default(draft)
  createdById   String              @map("created_by_id") @db.Uuid
  finalizedById String?             @map("finalized_by_id") @db.Uuid
  finalizedAt   DateTime?           @map("finalized_at") @db.Timestamptz
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])
  photos   Photo[]

  @@index([locationId, activityDate])
  @@index([locationId, status])
  @@map("field_activities")
}

model DailyReportItem {
  id          String   @id @default(uuid()) @db.Uuid
  reportId    String   @map("report_id") @db.Uuid
  rabNodeId   String   @map("rab_node_id") @db.Uuid
  lineageKey  String   @map("lineage_key")
  volumeDone  Decimal  @map("volume_done") @db.Decimal(15, 3)
  valueDone   BigInt   @map("value_done")
  notes       String?
  reportedById String? @map("reported_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  report  DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  rabNode RabNode     @relation(fields: [rabNodeId], references: [id])
  photos  Photo[]

  @@unique([reportId, lineageKey])
  @@index([lineageKey])
  @@map("daily_report_items")
}

model DailyReportWorker {
  id       String     @id @default(uuid()) @db.Uuid
  reportId String     @map("report_id") @db.Uuid
  role     WorkerRole
  count    Int        @default(0)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, role])
  @@map("daily_report_workers")
}

model DailyReportMaterial {
  id          String   @id @default(uuid()) @db.Uuid
  reportId    String   @map("report_id") @db.Uuid
  name        String
  unit        String?
  qtyReceived Decimal? @map("qty_received") @db.Decimal(15, 3)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("daily_report_materials")
}

model DailyReportEquipment {
  id       String @id @default(uuid()) @db.Uuid
  reportId String @map("report_id") @db.Uuid
  name     String
  count    Int    @default(1)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("daily_report_equipment")
}

model Photo {
  id           String            @id @default(uuid()) @db.Uuid
  reportId     String?           @map("report_id") @db.Uuid
  reportItemId String?           @map("report_item_id") @db.Uuid
  activityId   String?           @map("activity_id") @db.Uuid
  r2Key        String            @unique @map("r2_key")
  thumbnailKey String?           @map("thumbnail_key")
  sha256       String            @unique
  bytes        Int
  widthPx      Int?              @map("width_px")
  heightPx     Int?              @map("height_px")
  exifGpsLat   Decimal?          @map("exif_gps_lat") @db.Decimal(10, 7)
  exifGpsLng   Decimal?          @map("exif_gps_lng") @db.Decimal(10, 7)
  exifTakenAt  DateTime?         @map("exif_taken_at") @db.Timestamptz
  verification PhotoVerification @default(pending)
  uploadedById String?           @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  report     DailyReport?     @relation(fields: [reportId], references: [id])
  reportItem DailyReportItem? @relation(fields: [reportItemId], references: [id])
  activity   FieldActivity?   @relation(fields: [activityId], references: [id])

  @@index([reportId])
  @@index([reportItemId])
  @@index([activityId])
  @@map("photos")
}

// ─────────────────────────────────────────────────────────────
// ISU & PEMULIHAN
// ─────────────────────────────────────────────────────────────

model Issue {
  id          String        @id @default(uuid()) @db.Uuid
  locationId  String        @map("location_id") @db.Uuid
  reportId    String?       @map("report_id") @db.Uuid
  title       String
  description String?
  severity    IssueSeverity @default(sedang)
  status      IssueStatus   @default(terbuka)
  raisedById  String?       @map("raised_by_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  location Location         @relation(fields: [locationId], references: [id])
  report   DailyReport?     @relation(fields: [reportId], references: [id])
  actions  RecoveryAction[]

  @@index([locationId, status])
  @@map("issues")
}

model RecoveryAction {
  id          String         @id @default(uuid()) @db.Uuid
  issueId     String         @map("issue_id") @db.Uuid
  description String
  picUserId   String?        @map("pic_user_id") @db.Uuid
  picName     String?        @map("pic_name")
  dueDate     DateTime?      @map("due_date") @db.Date
  status      RecoveryStatus @default(direncanakan)
  createdById String?        @map("created_by_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  issue   Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  updates RecoveryUpdate[]

  @@index([issueId])
  @@map("recovery_actions")
}

model RecoveryUpdate {
  id          String   @id @default(uuid()) @db.Uuid
  actionId    String   @map("action_id") @db.Uuid
  note        String
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  action RecoveryAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId, createdAt])
  @@map("recovery_updates")
}

// ─────────────────────────────────────────────────────────────
// KEUANGAN (transaction-based)
// ─────────────────────────────────────────────────────────────

model BudgetLine {
  id          String         @id @default(uuid()) @db.Uuid
  locationId  String         @map("location_id") @db.Uuid
  category    CostCategory
  amount      BigInt
  status      ApprovalStatus @default(disetujui)
  note        String?
  createdById String?        @map("created_by_id") @db.Uuid
  approvedById String?       @map("approved_by_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, category])
  @@map("budget_lines")
}

model Commitment {
  id          String         @id @default(uuid()) @db.Uuid
  locationId  String         @map("location_id") @db.Uuid
  vendorId    String?        @map("vendor_id") @db.Uuid
  type        CommitmentType
  number      String
  description String
  category    CostCategory
  amount      BigInt
  dueDate     DateTime?      @map("due_date") @db.Date
  status      ApprovalStatus @default(diajukan)
  createdById String?        @map("created_by_id") @db.Uuid
  approvedById String?       @map("approved_by_id") @db.Uuid
  approvedAt  DateTime?      @map("approved_at") @db.Timestamptz
  closedAt    DateTime?      @map("closed_at") @db.Timestamptz
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  location Location  @relation(fields: [locationId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  expenses Expense[]
  invoices Invoice[]

  @@unique([locationId, number])
  @@index([locationId, status])
  @@map("commitments")
}

/// Realisasi pengeluaran (termasuk settlement kasbon)
model Expense {
  id                 String         @id @default(uuid()) @db.Uuid
  locationId         String         @map("location_id") @db.Uuid
  commitmentId       String?        @map("commitment_id") @db.Uuid
  category           CostCategory
  amount             BigInt
  txDate             DateTime       @map("tx_date") @db.Date
  description        String
  status             ApprovalStatus @default(diajukan)
  evidenceDocumentId String?        @map("evidence_document_id") @db.Uuid
  createdById        String?        @map("created_by_id") @db.Uuid
  approvedById       String?        @map("approved_by_id") @db.Uuid
  approvedAt         DateTime?      @map("approved_at") @db.Timestamptz
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz

  location   Location    @relation(fields: [locationId], references: [id])
  commitment Commitment? @relation(fields: [commitmentId], references: [id])
  evidence   Document?   @relation("expenseEvidence", fields: [evidenceDocumentId], references: [id])

  @@index([locationId, txDate])
  @@index([commitmentId])
  @@map("expenses")
}

model Invoice {
  id           String        @id @default(uuid()) @db.Uuid
  locationId   String        @map("location_id") @db.Uuid
  commitmentId String?       @map("commitment_id") @db.Uuid
  number       String
  amount       BigInt
  invoiceDate  DateTime      @map("invoice_date") @db.Date
  dueDate      DateTime?     @map("due_date") @db.Date
  status       InvoiceStatus @default(diajukan)
  createdById  String?       @map("created_by_id") @db.Uuid
  approvedById String?       @map("approved_by_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  location   Location     @relation(fields: [locationId], references: [id])
  commitment Commitment?  @relation(fields: [commitmentId], references: [id])
  payments   PaymentOut[]

  @@unique([locationId, number])
  @@index([locationId, status])
  @@map("invoices")
}

model PaymentOut {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  amount      BigInt
  paidDate    DateTime @map("paid_date") @db.Date
  note        String?
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments_out")
}

/// Tagihan ke owner (KKP) per termin/MC
model OwnerBilling {
  id            String        @id @default(uuid()) @db.Uuid
  contractId    String        @map("contract_id") @db.Uuid
  terminNo      Int           @map("termin_no")
  description   String?
  amount        BigInt
  retentionHeld BigInt        @default(0) @map("retention_held")
  billedDate    DateTime?     @map("billed_date") @db.Date
  status        BillingStatus @default(draft)
  createdById   String?       @map("created_by_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  contract      Contract       @relation(fields: [contractId], references: [id])
  disbursements Disbursement[]

  @@unique([contractId, terminNo])
  @@map("owner_billings")
}

model Disbursement {
  id             String   @id @default(uuid()) @db.Uuid
  ownerBillingId String   @map("owner_billing_id") @db.Uuid
  amount         BigInt
  receivedDate   DateTime @map("received_date") @db.Date
  note           String?
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  ownerBilling OwnerBilling @relation(fields: [ownerBillingId], references: [id])

  @@index([ownerBillingId])
  @@map("disbursements")
}

// ─────────────────────────────────────────────────────────────
// ADMINISTRASI & DOKUMEN
// ─────────────────────────────────────────────────────────────

model AdminMilestone {
  id                   String          @id @default(uuid()) @db.Uuid
  packageId            String          @map("package_id") @db.Uuid
  locationId           String?         @map("location_id") @db.Uuid
  templateKey          String          @map("template_key")
  name                 String
  phase                AdminPhase
  sortOrder            Int             @default(0) @map("sort_order")
  picUserId            String?         @map("pic_user_id") @db.Uuid
  dueDate              DateTime?       @map("due_date") @db.Date
  status               MilestoneStatus @default(belum_dimulai)
  requiresVerification Boolean         @default(false) @map("requires_verification")
  completedAt          DateTime?       @map("completed_at") @db.Timestamptz
  verifiedById         String?         @map("verified_by_id") @db.Uuid
  note                 String?
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  package   Package    @relation(fields: [packageId], references: [id])
  location  Location?  @relation(fields: [locationId], references: [id])
  documents Document[]

  @@index([packageId, phase, sortOrder])
  @@index([locationId])
  @@map("admin_milestones")
}

model Document {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  packageId    String?      @map("package_id") @db.Uuid
  contractId   String?      @map("contract_id") @db.Uuid
  locationId   String?      @map("location_id") @db.Uuid
  amendmentId  String?      @map("amendment_id") @db.Uuid
  milestoneId  String?      @map("milestone_id") @db.Uuid
  phase        AdminPhase
  type         DocumentType
  title        String
  docNumber    String?      @map("doc_number")
  docDate      DateTime?    @map("doc_date") @db.Date
  expiryDate   DateTime?    @map("expiry_date") @db.Date
  description  String?
  r2Key        String       @unique @map("r2_key")
  fileName     String       @map("file_name")
  mimeType     String       @map("mime_type")
  bytes        Int
  sha256       String
  supersedesId String?      @map("supersedes_id") @db.Uuid
  uploadedById String       @map("uploaded_by_id") @db.Uuid
  uploadedAt   DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz

  organization Organization       @relation(fields: [orgId], references: [id])
  package      Package?           @relation(fields: [packageId], references: [id])
  contract     Contract?          @relation(fields: [contractId], references: [id])
  location     Location?          @relation(fields: [locationId], references: [id])
  amendment    ContractAmendment? @relation(fields: [amendmentId], references: [id])
  milestone    AdminMilestone?    @relation(fields: [milestoneId], references: [id])
  supersedes   Document?          @relation("docVersions", fields: [supersedesId], references: [id])
  versions     Document[]         @relation("docVersions")
  rabRevisions RabRevision[]      @relation("rabSourceDoc")
  expenses     Expense[]          @relation("expenseEvidence")

  @@index([packageId, phase])
  @@index([locationId, phase])
  @@index([orgId, sha256])
  @@index([type])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// SISTEM
// ─────────────────────────────────────────────────────────────

/// APPEND-ONLY (trigger): diisi helper audit() pada setiap mutasi
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  ip           String?
  payload      Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Alert {
  id             String        @id @default(uuid()) @db.Uuid
  locationId     String        @map("location_id") @db.Uuid
  alertType      String        @map("alert_type")
  severity       AlertSeverity
  message        String
  triggeredAt    DateTime      @default(now()) @map("triggered_at") @db.Timestamptz
  acknowledgedById String?     @map("acknowledged_by_id") @db.Uuid
  resolvedAt     DateTime?     @map("resolved_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, resolvedAt])
  @@map("alerts")
}

/// Setting effective-dated (mis. ppn_percent default)
model AppSetting {
  id            String   @id @default(uuid()) @db.Uuid
  key           String
  value         String
  effectiveFrom DateTime @map("effective_from") @db.Date
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([key, effectiveFrom])
  @@map("app_settings")
}
